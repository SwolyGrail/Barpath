<svg width="512" height="512" viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="bp" x1="120" y1="80" x2="392" y2="432" gradientUnits="userSpaceOnUse">
      <stop offset="0" stop-color="#2f7bff"/>
      <stop offset="1" stop-color="#19c3ff"/>
    </linearGradient>
    <radialGradient id="glow" cx="0.5" cy="0.36" r="0.75">
      <stop offset="0" stop-color="#123" stop-opacity="0.95"/>
      <stop offset="0.55" stop-color="#0a0a0c" stop-opacity="0"/>
    </radialGradient>
    <filter id="soft" x="-30%" y="-30%" width="160%" height="160%">
      <feGaussianBlur stdDeviation="7"/>
    </filter>
  </defs>

  <!-- tile -->
  <rect x="0" y="0" width="512" height="512" rx="116" fill="#0a0a0c"/>
  <rect x="0" y="0" width="512" height="512" rx="116" fill="url(#glow)"/>

  <!-- soft glow underlay of the path -->
  <g opacity="0.55" filter="url(#soft)">
    <path d="M232 100 C 360 156 360 214 256 256 C 152 298 152 358 282 414"
          fill="none" stroke="url(#bp)" stroke-width="40" stroke-linecap="round"/>
  </g>

  <!-- the bar path -->
  <path d="M232 100 C 360 156 360 214 256 256 C 152 298 152 358 282 414"
        fill="none" stroke="url(#bp)" stroke-width="36" stroke-linecap="round"/>

  <!-- plate / ring riding the path (upper) -->
  <g>
    <circle cx="330" cy="178" r="50" fill="#0a0a0c"/>
    <circle cx="330" cy="178" r="50" fill="none" stroke="url(#bp)" stroke-width="17"/>
    <circle cx="330" cy="178" r="15" fill="none" stroke="url(#bp)" stroke-width="11"/>
  </g>

  <!-- plate / ring riding the path (lower) -->
  <g>
    <circle cx="182" cy="336" r="50" fill="#0a0a0c"/>
    <circle cx="182" cy="336" r="50" fill="none" stroke="url(#bp)" stroke-width="17"/>
    <circle cx="182" cy="336" r="15" fill="none" stroke="url(#bp)" stroke-width="11"/>
  </g>
</svg>
